# ── Required ───────────────────────────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Models ─────────────────────────────────────────────────────────────────────
# RAG module uses Sonnet; LangChain module uses Haiku. Change here to swap models.
SONNET_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000

# ── Optional: LangSmith Tracing ────────────────────────────────────────────────
# Sign up free at: https://smith.langchain.com/
# When set, all LangChain calls are traced automatically in the LangSmith dashboard.
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=ai-learning-hub
